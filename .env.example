# Polygon wallet private key (no 0x prefix). Required for live trading.
POLYMARKET_PRIVATE_KEY=

# Polymarket proxy/funder address (Magic/email wallets). Leave empty for EOA.
POLYMARKET_FUNDER_ADDRESS=

# 0 = EOA (MetaMask), 1 = Magic/email proxy wallet
POLYMARKET_SIGNATURE_TYPE=0

# Scan-only by default. Set true to place orders when opportunities are found.
EXECUTE_TRADES=false

# Minimum net edge per share pair (e.g. 0.01 = 1 cent on a $1 payout)
MIN_PROFIT_PER_SHARE=0.01

# Estimated taker fee as fraction of notional (0.0 = ignore fees in filter)
TAKER_FEE_RATE=0.0

# Max USDC to spend per leg when executing (market buy amount in dollars)
MAX_ORDER_USDC=25

# Minimum shares per side (Polymarket often requires 5+)
MIN_ORDER_SIZE=5

# Scanner tuning
SCAN_INTERVAL_SECONDS=30
GAMMA_PAGE_SIZE=100
MAX_MARKETS_PER_SCAN=500
MAX_CONCURRENT_PRICE_REQUESTS=20

# Logging: DEBUG, INFO, WARNING
LOG_LEVEL=INFO
